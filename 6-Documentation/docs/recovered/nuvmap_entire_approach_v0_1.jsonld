      "name": "Invariant Candidate",
      "description": "A feature that appears to survive projection, compression, perturbation, or translation."
    },
    {
      "@id": "urn:nuvmap:gate:control-transfer",
      "@type": "Gate",
      "name": "REFUSE_CONTROL_TRANSFER",
